# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=nissaet_db
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_id
GITHUB_CLIENT_SECRET=your_github_secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_for_production

# Admin Registration Code
ADMIN_REGISTRATION_CODE=change_this_admin_code

# Server Port (optional)
PORT=5001

# S3 / Spaces / Wasabi Configuration
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_REGION=auto
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_BUCKET=your_bucket
# Optional: Base URL for public files (e.g. https://your-bucket.nyc3.digitaloceanspaces.com)
S3_PUBLIC_BASE_URL=
# Optional: Force path-style URLs for some providers
S3_FORCE_PATH_STYLE=false
# Optional: Max upload size in MB
MAX_UPLOAD_MB=15
